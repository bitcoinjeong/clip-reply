# === ClipReply Backend - Environment Variables ===
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# LLM Configuration
LLM_PROVIDER=ollama-cloud          # "ollama-cloud" or "openai"
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://ollama.com
LLM_MODEL=gemma4:31b-cloud

# Proxy (cloud deployment only - YouTube blocks cloud IPs)
# PROXY_URL=http://user:pass@proxy.example.com:8080

# CORS (comma-separated frontend origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
