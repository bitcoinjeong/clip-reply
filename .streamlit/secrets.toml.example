# === ClipReply - Secrets Template ===
# Copy this file to secrets.toml and fill in your values:
#   cp secrets.toml.example secrets.toml

# === LLM Configuration ===

# LLM_PROVIDER: "ollama-cloud" or "openai"
LLM_PROVIDER = "ollama-cloud"

# --- Option 1: Ollama Cloud + gemma4:31b-cloud (default, free) ---
LLM_API_KEY = "your-ollama-cloud-api-key"
LLM_BASE_URL = "https://ollama.com"
LLM_MODEL = "gemma4:31b-cloud"

# --- Option 2: Groq (free tier) ---
# LLM_PROVIDER = "openai"
# LLM_API_KEY = "gsk_..."
# LLM_BASE_URL = "https://api.groq.com/openai/v1"
# LLM_MODEL = "llama-3.3-70b-versatile"

# --- Option 3: OpenAI ---
# LLM_PROVIDER = "openai"
# LLM_API_KEY = "sk-..."
# LLM_BASE_URL = "https://api.openai.com/v1"
# LLM_MODEL = "gpt-4o-mini"

# --- Option 4: Local Ollama ---
# LLM_PROVIDER = "openai"
# LLM_API_KEY = "ollama"
# LLM_BASE_URL = "http://localhost:11434/v1"
# LLM_MODEL = "llama3.1"

# === Proxy (cloud deployment only) ===
# YouTube blocks cloud provider IPs. Use a residential/datacenter proxy.
# Free option: Webshare (https://www.webshare.io)
# PROXY_URL = "http://user:pass@proxy.example.com:8080"
